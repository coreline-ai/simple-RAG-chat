# Ollama 설정
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=qwen2.5-coder:7b
EMBEDDING_MODEL=bge-m3

# LLM 제공자 설정
# 지원 가능한 값: ollama (기본값), claude, codex
# ollama: 로컬 Ollama (qwen2.5-coder:7b)
# claude: OpenAI 호환 프록시를 통한 Claude
# codex: OpenAI 호환 프록시를 통한 Codex
LLM_PROVIDER=ollama

# OpenAI 호환 프록시 설정
# claude/codex 사용 시 필요
PROXY_API_URL=http://localhost:8080
PROXY_API_KEY=your-cli-proxy-api-key
CLAUDE_MODEL=claude-sonnet-latest
CODEX_MODEL=gpt-5-codex
LLM_ROUTING_MODE=stable
CODEX_PROXY_ENABLED=true
CODEX_DIRECT_ENABLED=true
CODEX_DIRECT_BASE_URL=https://chatgpt.com/backend-api
CODEX_AUTH_PATH=~/.codex/auth.json
CODEX_FALLBACK_AUTH_PATH=~/.chatgpt-codex-proxy/tokens.json
LLM_SELFTEST_ON_STARTUP=false
LLM_WARMUP_ON_STARTUP=false

# 벡터 DB 설정
# 지원 가능한 값: chroma
VECTOR_DB_TYPE=chroma
CHROMA_PERSIST_DIR=./chroma_db

# 청킹(Chunking) 설정
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# 검색 설정
TOP_K=5
